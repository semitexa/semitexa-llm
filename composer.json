{
  "name": "semitexa/llm",
  "description": "Self-hosted LLM assistant for Semitexa Framework — console-based skill execution",
  "type": "semitexa-module",
  "license": "MIT",
  "authors": [
    {
      "name": "Semitexa",
      "email": "support@semitexa.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "semitexa/core": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Semitexa\\Llm\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Semitexa\\Llm\\Tests\\": "tests/"
    }
  },
  "keywords": [
    "semitexa",
    "llm",
    "ai",
    "assistant",
    "skills"
  ]
}
