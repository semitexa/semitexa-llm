{
    "name": "semitexa/llm",
    "description": "Self-hosted LLM assistant for Semitexa Framework \u2014 console-based skill execution",
    "tag": "semitexa, llm, assistant, console, skill-execution",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Semitexa",
            "email": "support@semitexa.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "semitexa/core": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Semitexa\\Llm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Semitexa\\Llm\\Tests\\": "tests/"
        }
    },
    "keywords": [
        "semitexa",
        "llm",
        "ai",
        "assistant",
        "skills"
    ]
}
